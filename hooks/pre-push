#!/bin/bash
# GRACE Test Gate — Pre-Push Hook
# ===================================
# Blocks push if any unit test fails.
# Designed for MIF services: identity-service, payment-service.
#
# Install: ln -sf ../../hooks/pre-push .git/hooks/pre-push
#     Or:  cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}[GRACE] Running unit test gate before push...${NC}"

# Detect solution root
SOLUTION_ROOT="${PWD}"
while [ ! -f "${SOLUTION_ROOT}/*.sln" ] && [ ! -f "${SOLUTION_ROOT}/IdentityService.sln" ] && [ ! -f "${SOLUTION_ROOT}/PaymentService.sln" ] && [ "${SOLUTION_ROOT}" != "/" ]; do
    SOLUTION_ROOT="$(dirname "${SOLUTION_ROOT}")"
done

if [ "${SOLUTION_ROOT}" = "/" ]; then
    SOLUTION_ROOT="${PWD}"
fi

echo -e "${YELLOW}[GRACE] Solution root: ${SOLUTION_ROOT}${NC}"

# Run unit tests (exclude integration tests that require Docker)
dotnet test "${SOLUTION_ROOT}" \
    --no-restore \
    --filter "FullyQualifiedName!~Integration" \
    --verbosity minimal 2>&1

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo -e "${RED}❌ [GRACE] Unit tests FAILED. Push blocked.${NC}"
    echo -e "${RED}   Fix failing tests or use --no-verify to bypass (not recommended).${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ [GRACE] All unit tests passed. Proceeding with push.${NC}"
exit 0
